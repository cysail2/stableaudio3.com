# Clerk account UI.
# Required for sign-in, signup, account sync, credit balance, and generation.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Site API base and app id are configured in project/config/site.ts:
# apiServiceUrl: https://svc.stableaudio3.com
# appIdentifier: stableaudio3
# Do not add NEXT_PUBLIC_API_BASE or NEXT_PUBLIC_APP_ID unless the project
# deliberately moves these values back to runtime environment config.

# Optional environment selector for the team login endpoint.
# Leave empty for production. Use "test" only when the backend team wants
# loginAuthCyTest instead of loginAuth.
NEXT_PUBLIC_APP_ENV=

# Temporary audio model upstream
# Server-only values used by app/api/stable-audio/* to proxy ACE Step while the
# official Stable Audio 3 backend is not ready.
ACE_STEP_API_BASE=https://svc.grokimagineai.net

# Optional server-only app id override for temporary upstream calls.
# Defaults to project/config/site.ts appIdentifier.
APP_ID=
# SITE_APP_ID=
